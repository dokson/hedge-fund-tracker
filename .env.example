# ── Required for the multi-user app (Docker / production) ─────────────────────
# Generate fresh values with: python scripts/generate_secrets.py
# Never commit real values; only this template with placeholders.

# Postgres password (user/db are hardcoded to "hft" in docker-compose.yml).
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
POSTGRES_PASSWORD="REPLACE_ME_with_a_strong_random_password"

# Envelope-encryption master key (KEK). 32-byte url-safe base64.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MASTER_KEY="REPLACE_ME_with_a_freshly_generated_Fernet_key"
MASTER_KEY_VERSION=1

# JWT signing secrets for email-verify and password-reset links. 32+ random bytes.
# Generate each: python -c "import secrets; print(secrets.token_urlsafe(32))"
RESET_PASSWORD_TOKEN_SECRET="REPLACE_ME_with_a_random_32_byte_secret"
VERIFICATION_TOKEN_SECRET="REPLACE_ME_with_a_DIFFERENT_random_32_byte_secret"

# ── Legacy / optional API keys (env-var path; deprecated for AI providers) ────

# GitHub Token - Get your token at https://github.com/settings/tokens
GITHUB_TOKEN="your_github_token_here"

# Google AI Studio API Key - Get your free key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY="your_google_api_key_here"

# Groq API Key - Get your free key at https://console.groq.com/keys
GROQ_API_KEY="your_groq_api_key_here"

# Hugging Face Token - Get your free token at https://huggingface.co/settings/tokens
HF_TOKEN="your_huggingface_token_here"

# OpenRouter API Key - Get your free key at https://openrouter.ai/settings/keys
OPENROUTER_API_KEY="your_openrouter_api_key_here"

# OpenFIGI API Key - Get your free key at https://www.openfigi.com/api (raises rate limit from 25 to 250 req/min)
OPENFIGI_API_KEY="your_openfigi_api_key_here"

# Financial Modeling Prep API Key (optional) - Powers reverse ticker→CUSIP lookup for Form 4 filings.
# Without it, unresolved tickers open a GitHub issue and stay unmapped until the next 13F cycle.
# Get your free key at https://site.financialmodelingprep.com/developer/docs (250 req/day)
FMP_API_KEY="your_fmp_api_key_here"
