[[source]]
url = "https://pypi.org/simple"
verify_ssl = true
name = "pypi"

[requires]
python_version = "3.13"

[packages]
alembic = "~=1.18"
asyncpg = "~=0.31"
beautifulsoup4 = "~=4.14"
cryptography = "~=48.0"
fastapi = "~=0.136"
fastapi-users = {extras = ["sqlalchemy"], version = "~=15.0"}
fastapi-users-db-sqlalchemy = "~=7.0"
financedatabase = "~=2.3"
finnhub-python = "~=2.4"
google-genai = "~=2.2"
httptools = {version = "==0.7.1", markers = "sys_platform != 'win32'"}
lxml = "~=6.1"
openai = "~=2.36"
pandas = "~=2.3"
psutil = "~=7.2"
python-dotenv = "~=1.2"
python-multipart = "~=0.0"
python-toon = "~=0.1"
requests = "~=2.34"
slowapi = "~=0.1"
sqlalchemy = "~=2.0"
tabulate = "~=0.10"
tradingview-datafeed = "~=2.1"
uvicorn = "~=0.47"
uvloop = {version = "==0.22.1", markers = "sys_platform != 'win32'"}
watchfiles = "~=1.1"
websockets = "~=16.0"

[dev-packages]
mypy = "~=2.1"
pandas-stubs = "~=3.0"
pre-commit = "~=4.6"
ruff = "~=0.15"
types-requests = "~=2.33"
types-tabulate = "~=0.10"

[pipenv]
allow_prereleases = false

[scripts]
app = "python -m app.main"
app-cli = "python -m app.main --cli"
build-frontend = "cd app/frontend && npm install && npm run build"
build-gh-pages = "cd app/frontend && npm install && npm run build:gh-pages"
docker-up = "python scripts/docker_up.py -d --build"
test = "python -m unittest discover"
test-frontend = "cd app/frontend && npm test"
update = "python -m database.updater"
lint = "ruff check ."
lint-fix = "ruff check --fix ."
format = "ruff format ."
typecheck = "mypy app database scripts"
