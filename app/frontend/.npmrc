# ESLint 10 has stricter peer-dep ranges than some still-mainstream plugins
# (eslint-plugin-jsx-a11y@6.10.x declares peer eslint <=^9). The plugin's
# rules execute fine on ESLint 10 — kept on legacy-peer-deps until upstream
# bumps the peer range. Revisit when jsx-a11y publishes a major with eslint
# ^10 in peerDependencies.
legacy-peer-deps=true
